{
    "name": "@ni-private/eslint-config-nimble",
    "version": "1.0.0",
    "private": true,
    "description": "Shared ESLint configuration for FAST web component development",
    "keywords": ["eslint", "eslintconfig", "ni", "nimble"],
    "scripts": {
        "lint": "eslint .",
        "format": "eslint . --fix"
    },
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": "./index.js"
        },
        "./*": {
            "import": "./*/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ni/nimble.git"
    },
    
    "author": "National Instruments",
    "license": "MIT",
    "files": [
        "**/*.js",
        "!/eslint.config.*"
    ],
    "peerDependencies": {
        "@eslint/markdown": "^8.0.1",
        "@ni/eslint-config-angular": "^12.0.1",
        "@ni/eslint-config-javascript": "^5.1.4",
        "@ni/eslint-config-typescript": "^5.0.6",
        "eslint": "^9.36.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-markdown-links": "^0.9.0",
        "eslint-plugin-markdown-preferences": "^0.41.1",
        "typescript-eslint": "^8.59.1",
        "globals": "^17.6.0"
    }
}
