{
  "compilerOptions": {
    "target": "ES2020",
    "types": ["node", "jasmine"],
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "./dist/esm",
    "importHelpers": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  "include": [
    "src"
  ]
}
