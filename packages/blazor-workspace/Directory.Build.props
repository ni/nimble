<Project>
  <PropertyGroup>
    <!-- The codebase uses C# 14 language features, pin for consistency across framework versions. -->
    <LangVersion>14.0</LangVersion>
    <!--
      Suppressed warnings (see NoWarn) and warnings that should never fail the build (see
      WarningsNotAsErrors). These are environmental/restore concerns rather than code quality:
        NU1701 - Package was restored using a different target framework (compatibility fallback).
        NU1900 - Unable to contact the package source during restore (transient/offline).
        CS0122 - Member is inaccessible due to its protection level (generated code that targets inaccessible members in comments).
    -->
    <WarningsNotAsErrors>;NU1701;NU1900;CS0122</WarningsNotAsErrors>
    <NoWarn>;NU1701;NU1900;CS0122</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <TreatWarningsAsErrors>True</TreatWarningsAsErrors>
  </PropertyGroup>
</Project>
