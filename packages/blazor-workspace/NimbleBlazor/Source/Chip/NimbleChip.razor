@namespace NimbleBlazor
<nimble-chip
    selectable="@Selectable"
    selected="@Selected"
    removable="@Removable"
    disabled="@Disabled"
    @onnimblechipremove="HandleRemove"
    @onnimblechipselectedchange="HandleSelectedChange"
    appearance="@Appearance.ToAttributeValue()"
    @attributes="AdditionalAttributes">
    @ChildContent
</nimble-chip>
