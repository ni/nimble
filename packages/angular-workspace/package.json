{
  "name": "@ni-private/angular-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace for Angular projects",
  "scripts": {
    "app-start": "npm run start -w example-client-app",
    "app-performance": "npm run performance -w example-client-app",
    "nimble-build": "turbo run @ni/nimble-angular#build --log-order=grouped",
    "nimble-lint": "turbo run @ni/nimble-angular#lint",
    "nimble-format": "turbo run @ni/nimble-angular#format",
    "nimble-test": "turbo run @ni/nimble-angular#test",
    "nimble-tdd": "npm run tdd -w @ni/nimble-angular",
    "nimble-watch": "npm run watch -w @ni/nimble-angular",
    "lint": "eslint .",
    "format": "eslint . --fix"
  },
  "type": "module",
  "dependencies": {
    "@angular/animations": "^20.3.15",
    "@angular/common": "^20.3.15",
    "@angular/compiler": "^20.3.15",
    "@angular/core": "^20.3.15",
    "@angular/forms": "^20.3.15",
    "@angular/localize": "^20.3.15",
    "@angular/platform-browser": "^20.3.15",
    "@angular/platform-browser-dynamic": "^20.3.15",
    "@angular/router": "^20.3.15",
    "@ni/nimble-components": "*",
    "@ni/ok-components": "*",
    "@ni/spright-components": "*",
    "@ni/unit-format": "*",
    "rxjs": "^7.4.0",
    "tslib": "^2.2.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.15",
    "@angular/cli": "^20.3.15",
    "@angular/compiler-cli": "^20.3.15",
    "@lhci/cli": "^0.15.0",
    "@ni-private/eslint-config-nimble": "*",
    "@ni-private/jasmine-extensions": "*",
    "@ni/eslint-config-angular": "^12.0.0",
    "@ni/eslint-config-javascript": "^5.1.4",
    "@ni/fast-web-utilities": "^10.0.0",
    "@ni/jasmine-parameterized": "*",
    "@ni/nimble-tokens": "*",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/jasmine": "^5.1.13",
    "jasmine-core": "^5.7.0",
    "karma": "^6.3.0",
    "karma-chrome-launcher": "^3.1.0",
    "karma-coverage": "^2.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.0.0",
    "karma-spec-reporter": "^0.0.36",
    "ng-packagr": "^20.3.2",
    "playwright": "1.58.1",
    "rollup": "^4.12.0",
    "typescript": "~5.8.3"
  }
}
