{
  "name": "@ni/nimble-angular",
  "version": "33.0.3",
  "description": "Angular components for the NI Nimble Design System",
  "scripts": {
    "build": "npm run build:generate-icons && npm run build:library",
    "build:generate-icons": "node ./build/generate-icons.mjs",
    "build:library": "ng build @ni/nimble-angular",
    "lint": "ng lint @ni/nimble-angular",
    "format": "ng lint @ni/nimble-angular --fix",
    "test": "ng test @ni/nimble-angular --watch=false",
    "tdd": "ng test @ni/nimble-angular --browsers=Chrome",
    "watch": "ng build @ni/nimble-angular --watch --configuration development",
    "pack": "cd ../dist/nimble-angular && npm pack",
    "invoke-publish": "npm run invoke-publish:setup && cd ../dist/nimble-angular && npm publish",
    "invoke-publish:setup": "npm run build:library"
  },
  "type": "module",
  "exports": {
    "./styles/*": {
      "sass": "./styles/*.scss"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ni/nimble.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "National Instruments"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ni/nimble/issues"
  },
  "homepage": "https://github.com/ni/nimble#readme",
  "dependencies": {
    "tslib": "^2.2.0"
  },
  "peerDependencies": {
    "@angular/common": "^20.3.15",
    "@angular/core": "^20.3.15",
    "@angular/forms": "^20.3.15",
    "@angular/localize": "^20.3.15",
    "@angular/router": "^20.3.15",
    "@ni/nimble-components": "^35.5.5",
    "@ni/unit-format": "^1.0.3"
  }
}
