{
    "compilerOptions": {
      "target": "ES2020",
      "module": "Node16",
      "types": ["jasmine"],
      "esModuleInterop": true,
      "moduleResolution": "node16",
      "rootDir": "src",
      "outDir": "./dist/esm",
      "importHelpers": false,
      "strict": true,
