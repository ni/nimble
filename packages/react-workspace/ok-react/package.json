{
  "name": "@ni/ok-react",
  "version": "0.9.22",
  "description": "React components for NI Ok Components",
  "keywords": [
    "ni",
    "ok",
    "react"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "pack": "npm pack",
    "test": "karma start karma.conf.cjs --single-run",
    "invoke-publish": "npm publish"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./*": {
      "types": "./dist/esm/*.d.ts",
      "import": "./dist/esm/*/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/esm/*",
        "dist/esm/*/index.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ni/nimble.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "National Instruments",
  "license": "MIT",
  "peerDependencies": {
    "@lit/react": "^1.0.8",
    "@ni/ok-components": "^1.6.5",
    "react": "^17 || ^18 || ^19"
  },
  "devDependencies": {
    "@ni/ok-components": "^1.6.5",
    "@ni-private/eslint-config-nimble": "*",
    "@types/jasmine": "^5.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jasmine-core": "^5.1.2",
    "karma": "^6.3.0",
    "karma-chrome-launcher": "^3.1.0",
    "karma-jasmine": "^5.1.0",
    "karma-vite": "^1.0.5",
    "playwright": "1.60.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~5.8.3"
  }
}
